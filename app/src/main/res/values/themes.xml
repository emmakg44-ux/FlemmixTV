<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Thème de base -->
    <style name="Theme.FlemmixTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorPrimary">#E50914</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

    <!-- Thème plein écran pour l'activité principale -->
    <style name="Theme.FlemmixTV.Fullscreen" parent="Theme.FlemmixTV">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

</resources>
